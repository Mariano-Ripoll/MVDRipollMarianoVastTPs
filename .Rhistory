# =========================================================
# Diagnóstico completo post-scraping (TP2 OEA)
# =========================================================
library(tidyverse)
library(here)
library(readr)
library(stringr)
raw_path <- here("TP2", "data", "oea_comunicados_raw.rds")
stopifnot(file.exists(raw_path))
comunicados <- read_rds(raw_path)
cat("\n==================== 1) ESTRUCTURA ====================\n")
glimpse(comunicados)
cat("\n==================== 2) RESUMEN GENERAL ====================\n")
comunicados |>
summarise(
n_docs = n(),
ids_unicos = n_distinct(id),
urls_unicas = n_distinct(url),
titulos_vacios = sum(is.na(titulo) | titulo == ""),
cuerpos_vacios = sum(is.na(cuerpo) | cuerpo == ""),
cuerpos_menor_200 = sum(nchar(cuerpo) < 200, na.rm = TRUE),
cuerpos_mayor_1000 = sum(nchar(cuerpo) > 1000, na.rm = TRUE),
largo_titulo_prom = round(mean(nchar(titulo), na.rm = TRUE), 1),
largo_cuerpo_prom = round(mean(nchar(cuerpo), na.rm = TRUE), 1)
) |>
print()
cat("\n==================== 3) PERIODO (debe ser 2026 y meses 1-4) ====================\n")
diag_periodo <- comunicados |>
mutate(
codigo = str_extract(url, "sCodigo=[^&]+") |> str_replace("sCodigo=", ""),
anio_2d = str_extract(codigo, "(?<=/)\\d{2}"),
anio = if_else(!is.na(anio_2d), as.integer(paste0("20", anio_2d)), NA_integer_),
mes = case_when(
str_detect(str_to_lower(cuerpo), "enero") ~ 1L,
str_detect(str_to_lower(cuerpo), "febrero") ~ 2L,
str_detect(str_to_lower(cuerpo), "marzo") ~ 3L,
str_detect(str_to_lower(cuerpo), "abril") ~ 4L,
TRUE ~ NA_integer_
)
)
diag_periodo |>
count(anio, sort = TRUE) |>
print(n = Inf)
cat("\n(Ojo: el mes inferido por texto puede tener NA si no aparece explícito en el cuerpo.)\n")
diag_periodo |>
count(mes, sort = TRUE) |>
print(n = Inf)
cat("\n==================== 4) CALIDAD DE TÍTULOS ====================\n")
comunicados |>
summarise(
titulos_largo_1 = sum(nchar(titulo) == 1, na.rm = TRUE),
titulos_menor_10 = sum(nchar(titulo) < 10, na.rm = TRUE),
titulo_A = sum(str_to_lower(titulo) == "a", na.rm = TRUE)
) |>
print()
cat("\nTop 20 títulos repetidos (para detectar ruido):\n")
comunicados |>
count(titulo, sort = TRUE) |>
slice_head(n = 20) |>
print(n = 20, width = Inf)
cat("\nMuestra de títulos + preview cuerpo:\n")
comunicados |>
transmute(
id, titulo,
nchar_cuerpo = nchar(cuerpo),
preview = str_sub(cuerpo, 1, 160),
url
) |>
slice_head(n = 15) |>
print(n = 15, width = Inf)
cat("\n==================== 5) RUIDO TÍPICO ====================\n")
comunicados |>
summarise(
ruido_javascript = sum(str_detect(str_to_lower(cuerpo), "javascript"), na.rm = TRUE),
ruido_please = sum(str_detect(str_to_lower(cuerpo), "please"), na.rm = TRUE),
ruido_not_found = sum(str_detect(str_to_lower(cuerpo), "not found"), na.rm = TRUE),
ruido_site_map = sum(str_detect(str_to_lower(cuerpo), "site map"), na.rm = TRUE),
ruido_unavailable = sum(str_detect(str_to_lower(cuerpo), "temporarily unavailable|unavailable"), na.rm = TRUE)
) |>
print()
cat("\n==================== 6) VALIDACIÓN DE URL ====================\n")
comunicados |>
mutate(
url_ok = str_detect(url, "^https://www\\.oas\\.org/es/centro_noticias/comunicado_prensa\\.asp\\?sCodigo=")
) |>
count(url_ok) |>
print()
cat("\nEjemplos de URL:\n")
comunicados |>
select(url) |>
distinct() |>
slice_head(n = 20) |>
print(n = 20, width = Inf)
cat("\n==================== 7) ATRIBUTO DE FECHA ====================\n")
print(attr(comunicados, "fecha_descarga"))
cat("\n✅ Diagnóstico completo finalizado.\n")
