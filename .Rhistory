#install.packages("tidyverse")
#install.packages("janitor")
# install.packages("stringi")
library(tidyverse)
library(janitor)
library(stringi)
# CARGAR DATOS
ruta_internet = "../data/archivo.csv"
ruta_metadata = "../data/archivo_paises.csv"
internet_raw = read_csv(ruta_internet, skip = 4, show_col_types = FALSE)# La base de datos sobre indicadores de internet tien líneas iniciales previas a la tabla de metadatos, por eso el skip.
metadata_raw = read_csv(ruta_metadata, show_col_types = FALSE)
#Para limpiar el df buscamos homogeneizar y estandarizar los valores para cada variable de modo que distintas funciones o analisis estadisticos puedan considerar a todas iguales. Asimismo, es necesario a nivel teórico para no desvirtuar la información por medio de contenido erroneo/redundante/inecesario o simplemente no interpretable.
normalizar_df = function(dataframe, clean = TRUE, which_remove = "cols")
# En esta primera parte de la función buscamos normalizar lo que serían los nombres de columnas y sus posibles espacios o caracteres especiales.
{if (clean) {
data_clean = clean_names(dataframe)
} else {
data_clean = dataframe}
# Aquí, en cambio, buscamos limpiar respecto de valores faltantes o columnas vacías/sin nombrar.
if (which_remove == "both")
{ data_clean = data_clean |>
janitor::remove_empty(which = 'cols') |>
janitor::remove_empty(which = 'rows') }
else {
data_clean = janitor::remove_empty(data_clean, which = which_remove)
}
return(data_clean)
}
# LLamadO a las funciones de limpieza:
internet = normalizar_df(internet_raw, which_remove = "cols")
metadata = normalizar_df(metadata_raw, which_remove = "cols")
# Breve inspección:
glimpse(internet)
glimpse(metadata)
# Transformar base internet
# Internet esta en formato wide (años aparecen como una columna distintas)
# Lo que se busca en el codigo de aca es pasarlo a formato largo para que tenga algún sentido de sencillez analizar la evolución temporal.
internet_long <- internet |>
pivot_longer(
cols = -c(country_name, country_code, indicator_name, indicator_code),
names_to = "year",
values_to = "internet_users_pct"
)
# Me aseguro que el año este en formato numerico y filtro circunscribiendo al periodo de la hipotesis (ante la duda incluí ambos años 2013 y 2023 inclusive)
internet_long <- internet_long |>
mutate(
year = gsub("[^0-9]", "", year),
year = as.integer(year)
) |>
filter(
year >= 2013,
year <= 2023
)
#Exploración:
head(internet_long)
glimpse(internet_long)
# ARREGLO ADICIONAL DE MISSING VALUES
# Dado que algunos NA de la tabla se expresan como "..", convierto estos a NA.
internet_long = internet_long |>
mutate(
internet_users_pct=ifelse(internet_users_pct == "..", NA, internet_users_pct),
internet_users_pct=as.numeric(internet_users_pct)
)
# Hago check de faltantes, si son pocos lo puedo eliminarlos sin afectar relevantemente el resultado en términos teóricos.
n_missing=sum(is.na(internet_long$internet_users_pct))
print(n_missing)
#Si son pocos:
internet_long = internet_long|>
filter(!is.na(internet_users_pct))
#Así elimino observaciones sin datos.
# Transformar base países
metadata = metadata |>
select(country_code, region, income_group, table_name)
head(metadata)
# UNIR BASES DE DATOS
# Se unen pivoteando por country_code que es el clave común entre la tabla de indicadores de internet y metada (archivo de paises. )
base_unida = internet_long |>
left_join(metadata, by = "country_code")
head(base_unida)
glimpse(base_unida)
# Resto de la limpieza: hay observaciones sin clasificación de grupos de ingresos; tienden a corresponderse con categorías que no tienen injerencia para analizar las hipotesis; ergo, los quito.
base_limpia = base_unida |>
filter(!is.na(income_group))
#Reordenar los datos; se factorizan ordenadamente por income_group
base_limpia = base_limpia |>
mutate(
income_group = factor(
income_group,
levels = c(
"Low income",
"Lower middle income",
"Upper middle income",
"High income"
),
ordered = TRUE
)
)
levels(base_limpia$income_group)
#Agregado por región y año (se crea una tabla nueva)
tabla_region_anio = base_limpia |>
group_by(region, year) |>
summarise(
promedio_internet = mean(internet_users_pct, na.rm = TRUE),
cantidad_paises = n(),
.groups = "drop"
)
#Agregado por clasificación de ingresos y año
tabla_income_anio = base_limpia |>
group_by(income_group, year) |>
summarise(
promedio_internet = mean(internet_users_pct, na.rm = TRUE),
.groups = "drop"
)
# Orientación a Formato Ancho de la tabla
#Así es acorde a la tabla presentada en las consignas
resultado_hipotesis = tabla_income_anio |>
pivot_wider(
names_from = income_group,
values_from = promedio_internet
) |>
mutate(
indicator_name = "Individuals using the Internet (% of population)"
) |>
arrange(year)
#Orden jerarquico de columnas:
jerarquia = c(
"year",
"Low income",
"Lower middle income",
"Upper middle income",
"High income",
"indicator_name"
)
resultado_hipotesis = resultado_hipotesis |>
select(all_of(jerarquia))
resultado_hipotesis
View(normalizar_nombres)
View(normalizar_df)
View(resultado_hipotesis)
View(resultado_hipotesis)
