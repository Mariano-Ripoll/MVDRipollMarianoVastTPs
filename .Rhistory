metadata_raw = read_csv(ruta_metadata, show_col_types = FALSE)
#Para limpiar el df buscamos homogeneizar y estandarizar los valores para cada variable de modo que distintas funciones o analisis estadisticos puedan considerar a todas iguales. Asimismo, es necesario a nivel teórico para no desvirtuar la información por medio de contenido erroneo/redundante/inecesario o simplemente no interpretable.
normalizar_df = function(dataframe, clean = TRUE, which_remove = "cols")
# En esta primera parte de la función buscamos normalizar lo que serían los nombres de columnas y sus posibles espacios o caracteres especiales.
{if (clean) {
