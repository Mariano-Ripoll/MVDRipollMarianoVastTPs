#Analisis del crecimiento para la decada (2013-2023_)
# Para no solo quedarse con los niveles absolutos, se construye una tabla tambien con el crecimiento porcentual de cada grupo
crecimiento_2013_2023 = tabla_income_anio |>
filter(year == 2013 | year == 2023) |>
pivot_wider(
names_from = year,
values_from = promedio_internet
) |>
mutate(
crecimiento_absoluto = `2023` - `2013`,
crecimiento_porcentual = ((`2023` - `2013`) / `2013`) * 100
) |>
arrange(income_group)
crecimiento_2013_2023
View(crecimiento_2013_2023)
