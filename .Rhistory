library(tidyverse)
library(here)
library(readr)
# 1) Existen artefactos clave
files <- c(
here("TP2","data","oea_comunicados_raw.rds"),
here("TP2","output","processed_text.rds"),
here("TP2","output","frecuencia_5_terminos.rds"),
here("TP2","output","dtm_oea.rds")
)
print(file.exists(files))
# 2) Frecuencias reales desde output
freq_5 <- read_rds(here("TP2","output","frecuencia_5_terminos.rds"))
print(freq_5)
# 3) Recalcular desde tokens (control cruzado)
obj <- read_rds(here("TP2","output","processed_text.rds"))
tokens <- obj$processed_tokens
recalc <- tokens |>
count(id, lemma, name = "n") |>
group_by(lemma) |>
summarise(frecuencia_total = sum(n), .groups = "drop") |>
semi_join(freq_5, by = c("lemma")) |>
arrange(desc(frecuencia_total))
print(recalc)
# 4) Comparación exacta (debe dar TRUE en todas)
check <- freq_5 |>
arrange(lemma) |>
left_join(recalc |> arrange(lemma), by = "lemma", suffix = c("_archivo","_recalc")) |>
mutate(equal = frecuencia_total_archivo == frecuencia_total_recalc)
print(check)
frecuencia_5_terminos <- readRDS("~/GitHub/MVDRipollMarianoVastTPs/TP2/output/frecuencia_5_terminos.rds")
View(frecuencia_5_terminos)
